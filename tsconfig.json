{
"compilerOptions": {
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "bun",
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "test/**/*",
  ],
}
